{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://c411.org/**" },
        { "url": "https://alldebrid.fr/**" },
        { "url": "https://alldebrid.com/**" },
        { "url": "https://api.alldebrid.com/**" }
      ]
    },
    "store:default"
  ]
}